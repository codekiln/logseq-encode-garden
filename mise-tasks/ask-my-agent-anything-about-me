#!/usr/bin/env bash
set -euo pipefail

#MISE description="Ask My Agent Anything — launch whichever AI agent you have over this garden to answer questions about codekiln"

#USAGE flag "--tool <tool>" help="AI agent to use: claude, codex, cursor, or copilot (default: ask)" {
#USAGE   choices "claude" "codex" "cursor" "copilot"
#USAGE }
#USAGE flag "--generate" help="Regenerate this tool's skill config (rulesync) even if it already exists"

# Run from the graph root so the agent sees pages/, journals/, and the AI configs.
cd "${MISE_PROJECT_ROOT:-$PWD}"

SKILL="ask-my-agent-anything-about-me"
ALL_TOOLS=(claude codex cursor copilot)

# Tool registry: launcher binary, rulesync target, skill output dir, label.
tool_bin()    { case "$1" in claude) echo claude;; codex) echo codex;; cursor) echo cursor-agent;; copilot) echo copilot;; esac; }
tool_target() { case "$1" in claude) echo claudecode;; codex) echo codexcli;; cursor) echo cursor;; copilot) echo copilot;; esac; }
# Codex reads skills from the AGENTS.md-standard .agents/skills dir (committed); only
# Cursor's .cursor/skills is gitignored and generated on demand.
tool_dir()    { case "$1" in claude) echo .claude/skills;; codex) echo .agents/skills;; cursor) echo .cursor/skills;; copilot) echo .github/skills;; esac; }
tool_label()  { case "$1" in claude) echo "Claude Code";; codex) echo "Codex";; cursor) echo "Cursor";; copilot) echo "GitHub Copilot (free tier available)";; esac; }
tool_url()    { case "$1" in claude) echo "https://claude.com/claude-code";; codex) echo "https://developers.openai.com/codex";; cursor) echo "https://cursor.com";; copilot) echo "https://github.com/features/copilot";; esac; }

# Prefer rulesync on PATH (mise installs it); fall back to npx.
if command -v rulesync >/dev/null 2>&1; then
  RULESYNC=(rulesync)
else
  RULESYNC=(npx rulesync)
fi

# Choose the tool: explicit --tool, else ask which agent the visitor has.
chosen="${usage_tool:-}"
if [ -z "$chosen" ]; then
  echo "Which AI agent do you have? (GitHub Copilot has a free tier; the others need a paid plan.)" >&2
  menu=()
  for t in "${ALL_TOOLS[@]}"; do menu+=("$(tool_label "$t")"); done
  PS3="Enter a number (or Ctrl-C to quit): "
  select _ in "${menu[@]}"; do
    if [ "${REPLY:-}" -ge 1 ] 2>/dev/null && [ "$REPLY" -le "${#ALL_TOOLS[@]}" ]; then
      chosen="${ALL_TOOLS[$((REPLY - 1))]}"
      break
    fi
    echo "Please enter a number from the list." >&2
  done
  [ -z "${chosen:-}" ] && { echo "No selection made; exiting." >&2; exit 1; }
fi

target="$(tool_target "$chosen")"
dir="$(tool_dir "$chosen")"
bin="$(tool_bin "$chosen")"
label="$(tool_label "$chosen")"

# Generate this tool's skill config if it isn't committed yet (codex/cursor), or on --generate.
if [ "${usage_generate:-false}" = "true" ] || [ ! -f "$dir/$SKILL/SKILL.md" ]; then
  echo "Setting up the $label skill config (rulesync -> $target)..." >&2
  "${RULESYNC[@]}" generate --features skills --targets "$target"
fi

read -r -d '' kickoff <<'EOF' || true
Use the "ask-my-agent-anything-about-me" skill. You are codekiln's agent; answer
about codekiln and never speak in their first person. A visitor has cloned this
Logseq knowledge garden to get to know codekiln. Greet them in a sentence and
invite them to ask anything about codekiln. Answer only from the garden's pages
and journals, cite the source pages, and separate what is documented from what you
infer.
EOF

# If the chosen agent isn't installed, its config is ready regardless — point the
# visitor at the folder and the install link, then let them re-run.
if ! command -v "$bin" >/dev/null 2>&1; then
  cat <<EOF
$label ($bin) was not found on your PATH. Its skill config is ready at
$dir/$SKILL/ — open this folder in $label and ask anything about codekiln, or
install $label ($(tool_url "$chosen")) and re-run:
  mise run ask-my-agent-anything-about-me --tool $chosen
EOF
  exit 0
fi

echo "Starting $label. Ask anything about codekiln." >&2
case "$chosen" in
  copilot) exec "$bin" -p "$kickoff" ;;
  *)       exec "$bin" "$kickoff" ;;
esac
